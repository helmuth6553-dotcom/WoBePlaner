# Supabase Configuration
# Copy this file to .env.local and fill in your values

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sentry Error Tracking (Optional but recommended)
# Get your DSN from: https://sentry.io -> Project Settings -> Client Keys
VITE_SENTRY_DSN=your_sentry_dsn_here

# App Version (Used for Sentry release tracking)
VITE_APP_VERSION=1.0.0

# ========================================
# FEATURE FLAGS (Roadmap 2.0)
# ========================================
# Multi-Tenancy & DB-driven shift templates
# Set to 'true' to enable new features, 'false' to use legacy behavior
# SAFETY: If anything breaks, set this to 'false' to immediately rollback
VITE_FEATURE_MULTI_TENANCY=false
